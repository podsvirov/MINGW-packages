prepare() {
  #cd "${srcdir}/console-${_consolever}"

  #npm install


  cd "${srcdir}/${_realname}-${_pkgver}"

  unzip -o "${srcdir}/rustfs-console-v${_consolever}.zip" -d static

  #cargo fetch --locked --target "${RUST_CHOST}"


  cd "${srcdir}/launcher-${_launcherver}"

  patch -Np1 -i "${srcdir}"/0001-launcher-0.0.1-fix-reopen.patch

  mkdir -p src-tauri/binaries && cp "${srcdir}/rustfs.exe" "src-tauri/binaries/rustfs-windows-x86_64.exe"

  cargo fetch --target "${RUST_CHOST}"
}

build() {
  #cd "console-${_consolever}"

  #npm run build


  #cd "${_realname}-${_pkgver}"

  #export RUSTFLAGS="$RUSTFLAGS -C link-arg=-fuse-ld=lld"
  #export OPENSSL_NO_VENDOR=1

  #cargo run --bin gproto

  #cargo build --release --frozen -p rustfs --bins


  cd "${srcdir}/launcher-${_launcherver}"

  cargo tauri build --no-bundle
}

#check() {
#  cd "${_realname}-${_pkgver}"

#  cargo test --release --frozen
#}

package() {
  mkdir -p "${pkgdir}${MINGW_PREFIX}/bin"

  cd "${srcdir}/launcher-${_launcherver}"

#  cargo install \
#    --bin rustfs-launcher \
#    --offline \
#    --no-track \
#    --frozen \
#    --path . \
#    --root "${pkgdir}${MINGW_PREFIX}"

  install -Dm755 "target/release/rustfs-launcher.exe" "${pkgdir}${MINGW_PREFIX}/bin/rustfs-launcher.exe"


  cd "${srcdir}/${_realname}-${_pkgver}"

  install -Dm755 "${srcdir}/rustfs.exe" "${pkgdir}${MINGW_PREFIX}/bin/rustfs.exe"

  install -Dm644 LICENSE "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE"
}
