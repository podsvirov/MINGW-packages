_realname=rustfs
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=1.0.0
_pkgver=1.0.0-alpha.73
_consolever=0.0.12
_launcherver=0.0.1
pkgrel=1
pkgdesc="High-performance, memory-safe distributed object storage (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url='https://rustfs.com/'
license=('spdx:Apache-2.0')
makedepends=(
  "${MINGW_PACKAGE_PREFIX}-rust"
#  "${MINGW_PACKAGE_PREFIX}-nodejs"
#  "${MINGW_PACKAGE_PREFIX}-lld"
#  "${MINGW_PACKAGE_PREFIX}-pkgconf"
#  "${MINGW_PACKAGE_PREFIX}-openssl"
  "${MINGW_PACKAGE_PREFIX}-wasm-bindgen"
  "${MINGW_PACKAGE_PREFIX}-trunk"
  "${MINGW_PACKAGE_PREFIX}-cargo-tauri"
  'unzip'
)
source=(
  "https://github.com/rustfs/rustfs/archive/${_pkgver}/rustfs-${_pkgver}.tar.gz"
  "https://github.com/rustfs/rustfs/releases/download/${_pkgver}/rustfs-windows-x86_64-v${_pkgver}.zip"
  "https://github.com/rustfs/console/releases/download/v${_consolever}/rustfs-console-v${_consolever}.zip"
  "https://github.com/rustfs/launcher/archive/v${_launcherver}/launcher-${_launcherver}.tar.gz"
  '0001-launcher-0.0.1-fix-reopen.patch'
)
noextract=("rustfs-console-v${_consolever}.zip")
sha256sums=('30cb860177888dba33fa4e0b7a03259b2e21cd32690920be633850af2ef0ab4e'
            '9adc2e58d3a65c7aa53d7f46b91661f222c686213eb9050b0f1ed333e22b16b8'
            '80daffe86d6d94736bfed13970b09f788bf691add1c8f53896ed7898d9f8451f'
